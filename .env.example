# --- Base de datos ---
# Vacío en desarrollo => usa PGlite local (packages/db/.pglite), sin credenciales.
#
# Para Neon, guardá las connection strings con estos nombres (NO como
# DATABASE_URL): así `pnpm dev` sigue usando PGlite y ningún `db:reset`
# accidental borra producción. Pasá la variable explícitamente cuando haga falta:
#   DATABASE_URL="$DATABASE_URL_UNPOOLED" pnpm db:migrate
DATABASE_URL_POOLED=
DATABASE_URL_UNPOOLED=

# --- Autenticación (M5) ---
BETTER_AUTH_SECRET=
# Origen de la API (donde cuelga /auth/*), NO el de la web.
BETTER_AUTH_URL=http://localhost:8787
# Google Cloud Console → OAuth 2.0 Client ID. Sin esto, el login social no
# funciona pero email/password sí.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Frontend ---
# En dev el proxy de Vite reenvía /api al servidor Hono (puerto 8787).
# En prod: origen del proyecto API en Vercel (sin /api al final).
VITE_API_URL=/api

# --- API ---
PORT=8787
# Restringe CORS en producción al dominio de la web (deja vacío en dev).
WEB_ORIGIN=
