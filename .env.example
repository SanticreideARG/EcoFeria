# --- Base de datos ---
# Vacío en desarrollo => usa PGlite local (packages/db/.pglite), sin credenciales.
# Setear la connection string de Neon para usar Postgres gestionado.
DATABASE_URL=

# --- Autenticación (M5) ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Frontend ---
# En dev el proxy de Vite reenvía /api al servidor Hono (puerto 8787).
VITE_API_URL=/api

# --- API ---
PORT=8787
