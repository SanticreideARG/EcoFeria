{
  "name": "la-ecoferia",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c green,blue \"pnpm --filter @ecoferia/api dev\" \"pnpm --filter @ecoferia/web dev\"",
    "dev:web": "pnpm --filter @ecoferia/web dev",
    "dev:api": "pnpm --filter @ecoferia/api dev",
    "build": "pnpm --filter @ecoferia/web build",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,css,md,json,yaml}\"",
    "typecheck": "pnpm -r --if-present typecheck",
    "db:generate": "pnpm --filter @ecoferia/db generate",
    "db:migrate": "pnpm --filter @ecoferia/db migrate",
    "db:seed": "pnpm --filter @ecoferia/db seed",
    "db:reset": "pnpm --filter @ecoferia/db reset"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "sharp": "^0.34.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"],
    "overrides": {
      "better-call": "1.0.29"
    }
  }
}
